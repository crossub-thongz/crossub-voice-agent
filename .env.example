# CROSSUB Voice Agent — environment template.
# Copy to `.env` and fill in. `.env` is gitignored.

# --- LiveKit (LiveKit Cloud → Project → Settings → Keys) ---
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Speech-to-text: Deepgram (https://console.deepgram.com) ---
DEEPGRAM_API_KEY=

# --- Text-to-speech: ElevenLabs (https://elevenlabs.io) ---
ELEVENLABS_API_KEY=

# --- LLM: Anthropic Claude (https://console.anthropic.com) ---
ANTHROPIC_API_KEY=

# --- Optional model / voice overrides (defaults shown) ---
VOICE_STT_MODEL=nova-3
# STT language: "multi" attempts EN/中文 code-switching in one stream.
# If Chinese quality is poor, test a per-call language ("en" / "zh") instead — see README.
VOICE_STT_LANGUAGE=multi
VOICE_LLM_MODEL=claude-haiku-4-5
VOICE_TTS_MODEL=eleven_flash_v2_5
# A multilingual ElevenLabs voice id (blank = plugin default voice):
# VOICE_TTS_VOICE_ID=
VOICE_AGENT_NAME=crossub-inbound

# Enable LiveKit Cloud telephony noise cancellation (needs `uv sync --extra telephony`):
# VOICE_TELEPHONY_NOISE_CANCELLATION=true
