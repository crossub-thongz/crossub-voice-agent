# CROSSUB Voice Agent — environment template.
# Copy to `.env` and fill in. `.env` is gitignored.

# --- LiveKit (LiveKit Cloud → Project → Settings → Keys) ---
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Speech-to-text: Deepgram (https://console.deepgram.com) ---
DEEPGRAM_API_KEY=

# --- Text-to-speech: ElevenLabs (https://elevenlabs.io) ---
ELEVENLABS_API_KEY=

# --- LLM: Anthropic Claude (https://console.anthropic.com) ---
ANTHROPIC_API_KEY=

# --- Optional model / voice overrides (defaults shown) ---
VOICE_STT_MODEL=nova-3
# STT language: "multi" attempts EN/中文 code-switching in one stream.
# If Chinese quality is poor, test a per-call language ("en" / "zh") instead — see README.
VOICE_STT_LANGUAGE=multi
VOICE_LLM_MODEL=claude-haiku-4-5
# flash_v2_5 is low-latency AND supports enforced language codes (best for phone).
# For higher-quality 中文 at the cost of ~300ms latency, try eleven_multilingual_v2
# (note: it ignores/rejects language codes, so the per-language enforcement is off).
VOICE_TTS_MODEL=eleven_flash_v2_5
# English / default voice id (blank = plugin default voice):
# VOICE_TTS_VOICE_ID=
# Dedicated Chinese (中文) voice id — the agent switches to it when the caller
# speaks Chinese, so Mandarin sounds native instead of the English voice reading it
# with an accent. Blank = reuse the English voice (still improved by the enforced
# zh language code on flash/turbo v2.5). Grab one from the ElevenLabs Voice Library:
# elevenlabs.io/app/voice-library → filter Language = Chinese → pick a conversational
# voice → "Add to my voices" → copy its Voice ID here.
# VOICE_TTS_VOICE_ID_ZH=
VOICE_AGENT_NAME=crossub-inbound

# Enable LiveKit Cloud telephony noise cancellation (needs `uv sync --extra telephony`):
# VOICE_TELEPHONY_NOISE_CANCELLATION=true
