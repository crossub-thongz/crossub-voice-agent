# CROSSUB Voice Tester — server-side env (never exposed to the browser).
# Copy to `.env.local` and fill in. Same LiveKit project as the agent.

LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Must match the agent's VOICE_AGENT_NAME so the browser dispatches the right worker.
VOICE_AGENT_NAME=crossub-inbound
