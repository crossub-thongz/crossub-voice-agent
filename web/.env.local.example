# CROSSUB Tester — server-side env (never exposed to the browser).
# Copy to `.env.local` and fill in.

# --- Voice tester (LiveKit) ---
# Same LiveKit project as the agent.
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Must match the agent's VOICE_AGENT_NAME so the browser dispatches the right worker.
VOICE_AGENT_NAME=crossub-inbound

# --- Text / async-message triage tester ---
# The CROSSUB Nest API base URL (no trailing slash), e.g. staging:
#   https://crossub-api-staging.onrender.com
VOICE_API_BASE_URL=
# The SAME value as VOICE_SERVICE_TOKEN on the API (the x-voice-service-token shared secret).
VOICE_SERVICE_TOKEN=
